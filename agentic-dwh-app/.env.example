# ── Anthropic API ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Models ──
# Planning + final report model (the orchestrator).
MODEL=claude-sonnet-4-6
# Optional: run the 5 specialist agents on a faster/cheaper model (e.g. Haiku)
# while the orchestrator keeps MODEL. Falls back to MODEL if unset. Big speed-up.
# SPECIALIST_MODEL=claude-haiku-4-6

# ── Server ──
PORT=3000

# Note: behind a corporate SSL-inspection proxy, Node may need a CA bundle.
# Export your trusted roots to agentic-dwh-app/windows-ca.pem and the server
# will use it automatically (the file is git-ignored).
