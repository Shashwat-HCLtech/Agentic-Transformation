ANTHROPIC_API_KEY=sk-ant-...

# Snowflake (also referenced by ~/.dbt/profiles.yml)
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=DBT_DEV

# dbt-mcp
DBT_PROJECT_DIR=./dbt_project_snowflake
DBT_PROFILES_DIR=~/.dbt
DBT_PATH=dbt
# Optional — enables Semantic Layer + Discovery API tools in dbt-mcp
# DBT_HOST=cloud.getdbt.com
# DBT_TOKEN=
# DBT_PROD_ENV_ID=
# DBT_DEV_ENV_ID=
# DBT_USER_ID=

MODEL=claude-opus-4-7
